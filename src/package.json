  "scripts": {
    "test:watch": "mocha --require tsx/cjs --watch --reporter spec --recursive 'tests/**/*.test.ts'",
    "test": "npm run compile && npm run test:unit",
    "test:coverage": "npm run compile && c8 --reporter=text --reporter=html --report-dir=../coverage-report --include 'server/**' --include 'collections/**' --include 'lib/**' mocha --require tsx/cjs --recursive 'tests/**/*.test.ts'",
    "start": "meteor run",
    "compile": "./node_modules/.bin/tsc",
    "compile:watch": "./node_modules/.bin/tsc -w",
    "test:unit": "mocha --require tsx/cjs --reporter spec --recursive 'tests/**/*.test.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "cd .. && husky src/.husky || true",
    "dev": "(docker start jwpublic-mailpit 2>/dev/null || docker run -d --name jwpublic-mailpit -p 11025:1025 -p 18025:8025 axllent/mailpit) && MAIL_URL=smtp://localhost:11025 meteor run --port 4000",
    "types": "meteor lint"
  },
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,tsx,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,less,md,yml,html}": [
      "prettier --write"
    ]
  }
